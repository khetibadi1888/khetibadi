# Copy this to proxy/.env for local development
# NEVER commit the actual .env file

# Your Apps Script Web App URL (from Deploy → New deployment in Apps Script)
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Any long random string — run: python3 -c "import secrets; print(secrets.token_hex(32))"
PROXY_SECRET=replace_with_random_string

# Your GitHub Pages URL — no trailing slash
ALLOWED_ORIGINS=https://YOUR-USERNAME.github.io

# Port (Render sets this automatically)
PORT=5000
